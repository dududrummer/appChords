# ==============================================
# AppChords - Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no Git!
# ==============================================

# OpenAI (para scripts de extração de acordes)
OPENAI_API_KEY=sk-proj-...

# Google Gemini (para scripts de IA)
GEMINI_API_KEY=AIza...

# Supabase (chaves originais - para uso em scripts server-side)
PUBLISH_API_KEY=sb_publishable_...
PROJECT_URL=https://SEU-PROJETO.supabase.co

# Supabase (client-side - prefixo VITE_ obrigatório para o Vite expor ao browser)
# A ANON KEY é segura para o frontend - o RLS do Supabase protege os dados
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
